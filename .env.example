# GitHub Opportunity Radar — Environment Variables
# All values are optional. Copy this to .env to use.

# LLM provider: "ollama" | "openai_compatible" | "litellm_proxy"
LLM_PROVIDER=

# Ollama base URL (default: http://localhost:11434)
LLM_BASE_URL=

# API key (only needed for openai_compatible / litellm_proxy)
LLM_API_KEY=

# Model name (default: qwen2.5:14b)
LLM_MODEL=
